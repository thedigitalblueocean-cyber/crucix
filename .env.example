# TDBO Crucix — Environment Variables
# Copy to .env and fill in real values:
#   cp .env.example .env

# ── D-04: Arbitrum Sepolia Anchor ─────────────────────────────────────────
# Your deployer wallet private key (no 0x prefix needed by ethers v6)
PRIVATE_KEY=YOUR_PRIVATE_KEY_HERE

# Arbitrum Sepolia public RPC (default used if blank)
ARB_SEPOLIA_RPC=https://sepolia-rollup.arbitrum.io/rpc

# Filled automatically by npm run deploy-anchor
CONTRACT_ADDRESS=

# ── LLM / Intelligence Layer ──────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Telegram (TG dispatch channel) ───────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Discord (DC dispatch channel) ────────────────────────────────────────
DISCORD_WEBHOOK_URL=
